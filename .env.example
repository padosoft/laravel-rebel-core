# ─────────────────────────────────────────────────────────────────────────────
# padosoft/laravel-rebel-core — variabili d'ambiente
# ─────────────────────────────────────────────────────────────────────────────
# Il core usa un "pepper" segreto per gli HMAC (identificatori, IP, OTP...).
# NON committare i valori reali: questi vanno solo nel tuo .env / nei secrets.

# Pepper attivo (versione 1). Genera un valore robusto (>= 32 byte):
#   php -r "echo bin2hex(random_bytes(32));"
REBEL_PEPPER_V1=

# Versione di pepper usata per i NUOVI hash. Per ruotare: aggiungi REBEL_PEPPER_V2,
# definiscila in config/rebel-core.php e imposta REBEL_PEPPER_CURRENT=2.
REBEL_PEPPER_CURRENT=1

# Algoritmo HMAC (default consigliato: sha256).
REBEL_HMAC_ALGO=sha256

# Privacy/GDPR: salva IP e User-Agent come HMAC keyed invece che in chiaro.
REBEL_HASH_IP=true
REBEL_HASH_USER_AGENT=true
