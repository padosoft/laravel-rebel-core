# ─────────────────────────────────────────────────────────────────────────────
# padosoft/laravel-rebel-core — environment variables
# ─────────────────────────────────────────────────────────────────────────────
# The core uses a secret "pepper" for the HMACs (identifiers, IP, OTP...).
# Do NOT commit the real values: these go only in your .env / in your secrets.

# Active pepper (version 1). Generate a strong value (>= 32 bytes):
#   php -r "echo bin2hex(random_bytes(32));"
REBEL_PEPPER_V1=

# Pepper version used for NEW hashes. To rotate: add REBEL_PEPPER_V2,
# define it in config/rebel-core.php and set REBEL_PEPPER_CURRENT=2.
REBEL_PEPPER_CURRENT=1

# HMAC algorithm (recommended default: sha256).
REBEL_HMAC_ALGO=sha256

# Privacy/GDPR: store IP and User-Agent as a keyed HMAC instead of in cleartext.
REBEL_HASH_IP=true
REBEL_HASH_USER_AGENT=true
