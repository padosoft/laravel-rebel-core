{
    "name": "padosoft/laravel-rebel-core",
    "description": "Core primitives, value objects e contratti per Laravel Rebel: il control plane di autenticazione enterprise (assurance AAL/AMR, security context, audit, token Sanctum, rate-limiting). Porta d'ingresso dell'ecosistema padosoft/laravel-rebel-*.",
    "keywords": ["laravel", "authentication", "security", "otp", "passwordless", "step-up", "mfa", "passkey", "padosoft", "rebel"],
    "homepage": "https://github.com/padosoft/laravel-rebel-core",
    "license": "MIT",
    "authors": [
        {
            "name": "Padosoft",
            "email": "support@padosoft.com",
            "homepage": "https://www.padosoft.com"
        }
    ],
    "require": {
        "php": "^8.3",
        "illuminate/contracts": "^12.0|^13.0",
        "illuminate/support": "^12.0|^13.0",
        "psr/clock": "^1.0",
        "spatie/laravel-package-tools": "^1.92"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.18",
        "orchestra/testbench": "^10.0|^11.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "Padosoft\\Rebel\\Core\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Padosoft\\Rebel\\Core\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Padosoft\\Rebel\\Core\\RebelCoreServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "pest",
        "test-coverage": "pest --coverage",
        "phpstan": "phpstan analyse",
        "pint": "pint",
        "check": [
            "@pint --test",
            "@phpstan",
            "@test"
        ]
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
